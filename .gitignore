# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/

# Virtual environments
.venv/
venv/
env/

# Environment — never commit secrets
.env

# Data — large files; keep structure via .gitkeep
data/raw_pdfs/**
