data/extracted/**
!data/extracted/.gitkeep
data/chunks/**
!data/chunks/.gitkeep
data/indices/**
!data/indices/.gitkeep
data/*.sqlite
data/eval/results/**
!data/eval/results/.gitkeep
data/eval/questions.jsonl

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/

# Frontend
frontend/node_modules/
frontend/dist/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
